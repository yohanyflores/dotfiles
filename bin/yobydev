#!/usr/bin/env bash
# ==============================================================================
# Script: yobydev
# Descripción: Wrapper para levantar, conectar, sincronizar dotfiles y administrar
#              Dev Containers desde la terminal con estilo interactivo VS Code.
# ==============================================================================

set -euo pipefail

# --- CONFIGURACIÓN Y VALORES POR DEFECTO ---
DOTFILES_REPOSITORY="${DOTFILES_REPOSITORY:-git@github.com:yohanyflores/dotfiles.git}"
DOTFILES_INSTALL_COMMAND="${DOTFILES_INSTALL_COMMAND:-install-devcontainer.sh}"
YOBYDEV_CACHE_DIR="${YOBYDEV_CACHE_DIR:-$HOME/.cache/yobydev/tools}"

# Resuelve el target path para dotfiles
if [[ "${DOTFILES_TARGET_PATH:-}" == "~/"* ]]; then
    DOTFILES_TARGET_PATH="${HOME}/${DOTFILES_TARGET_PATH#~/}"
else
    DOTFILES_TARGET_PATH="${DOTFILES_TARGET_PATH:-}"
fi

# --- COLORES Y LOGS ---
log_info() {
    echo -e "\e[34m[yobydev:INFO]\e[0m $*"
}

log_warn() {
    echo -e "\e[33m[yobydev:WARN]\e[0m $*" >&2
}

log_error() {
    echo -e "\e[31m[yobydev:ERROR]\e[0m $*" >&2
}

# --- VERIFICACIONES EN EL HOST ---
for cmd in devcontainer docker jq node; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        log_error "El ejecutable requerido '$cmd' no está disponible en el host."
        exit 1
    fi
done

# Resolver rutas de caché
if [[ "$YOBYDEV_CACHE_DIR" == "~/"* ]]; then
    YOBYDEV_CACHE_DIR="${HOME}/${YOBYDEV_CACHE_DIR#~/}"
fi
mkdir -p "$YOBYDEV_CACHE_DIR"
YOBYDEV_CACHE_DIR=$(readlink -f "$YOBYDEV_CACHE_DIR")

# --- VARIABLES DE ESTADO GLOBALES ---
RESOLVED_PWD=$(readlink -f "$PWD")
CONTAINER_ID=""
CONTAINER_NAME=""
CONTAINER_STATE="missing" # running | exited | missing
CONFIG=""
CONFIG_FOR_CLI=""
YOBYDEV_SSH_MODE="none" # agent | keys | none
OVERRIDE_FILE=""

# --- PARSEAR ARGUMENTOS CLI (SUBCOMANDOS DIRECTOS) ---
ACTION=""
NO_CACHE=false
FORCE=false

show_help() {
    echo "yobydev — Dev Container Manager CLI (Estilo VS Code)"
    echo ""
    echo "Uso: yobydev [comando] [opciones]"
    echo ""
    echo "Comandos:"
    echo "  open      Levanta el dev container (si no existe) y conecta."
    echo "  reopen    Sincroniza dotfiles locales y conecta al contenedor."
    echo "  attach    Conecta directamente sin sincronizar dotfiles."
    echo "  rebuild   Reconstruye el dev container."
    echo "  start     Inicia un contenedor existente que está detenido."
    echo "  stop      Detiene el dev container."
    echo "  destroy   Detiene y elimina por completo el dev container."
    echo "  logs      Muestra los logs del dev container."
    echo ""
    echo "Opciones:"
    echo "  -c, --config <ruta> Especifica un archivo devcontainer.json específico para usar o forzar."
    echo "  -n, --no-cache      Reconstruye sin usar la caché de Docker (solo rebuild)."
    echo "  -f, --force         Omite las confirmaciones interactivas de acciones destructivas."
    echo "  -h, --help          Muestra esta ayuda."
    echo ""
    echo "Si se ejecuta sin comando, se abre un menú interactivo con el estado actual."
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        open|reopen|attach|rebuild|stop|destroy|logs|start)
            ACTION="$1"
            shift
            ;;
        -n|--no-cache)
            NO_CACHE=true
            shift
            ;;
        -f|--force)
            FORCE=true
            shift
            ;;
        -c|--config)
            if [[ $# -gt 1 ]]; then
                DEVCONTAINER_CONFIG="$2"
                shift 2
            else
                log_error "Falta especificar la ruta del archivo para --config"
                exit 1
            fi
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            log_error "Opción o comando desconocido: $1"
            show_help
            exit 1
            ;;
    esac
done

# --- DETECCIÓN DE CONTENEDOR EXISTENTE ---
detect_container() {
    local container_info
    container_info=$(docker ps -a --filter "label=devcontainer.local_folder=${RESOLVED_PWD}" --format "{{.ID}}|{{.Status}}|{{.Names}}" 2>/dev/null | head -1)

    if [[ -n "$container_info" ]]; then
        CONTAINER_ID=$(echo "$container_info" | cut -d'|' -f1)
        CONTAINER_NAME=$(echo "$container_info" | cut -d'|' -f3)

        if docker ps -q --filter "id=${CONTAINER_ID}" 2>/dev/null | grep -q .; then
            CONTAINER_STATE="running"
        else
            CONTAINER_STATE="exited"
        fi
    else
        CONTAINER_ID=""
        CONTAINER_NAME=""
        CONTAINER_STATE="missing"
    fi
}

# --- DETECCIÓN DE ARCHIVO DE CONFIGURACIÓN ---
detect_config() {
    # Si el usuario especificó explícitamente una configuración por variable de entorno o CLI, priorizarla siempre
    if [[ -n "${DEVCONTAINER_CONFIG:-}" ]]; then
        CONFIG="$DEVCONTAINER_CONFIG"
        if [[ ! -f "$CONFIG" ]]; then
            log_error "El archivo configurado en DEVCONTAINER_CONFIG no existe: $CONFIG"
            exit 1
        fi
        CONFIG=$(readlink -f "$CONFIG")
        CONFIG_FOR_CLI="$CONFIG"
        if [[ "$CONFIG" == "$RESOLVED_PWD/"* ]]; then
            CONFIG_FOR_CLI="${CONFIG#$RESOLVED_PWD/}"
        fi

        # Auto-completar ruta destino de dotfiles
        if [[ -z "$DOTFILES_TARGET_PATH" ]]; then
            local expected_user
            expected_user=$(node -e '
const fs = require("fs");
function stripComments(jsonc) {
  let isString = false;
  let isLineComment = false;
  let isBlockComment = false;
  let result = "";
  for (let i = 0; i < jsonc.length; i++) {
    const char = jsonc[i];
    const nextChar = jsonc[i + 1];
    if (isLineComment) {
      if (char === "\n" || char === "\r") {
        isLineComment = false;
        result += char;
      }
    } else if (isBlockComment) {
      if (char === "*" && nextChar === "/") {
        isBlockComment = false;
        i++;
      }
    } else if (isString) {
      if (char === "\"" && jsonc[i - 1] !== "\\") {
        isString = false;
      }
      result += char;
    } else {
      if (char === "/" && nextChar === "/") {
        isLineComment = true;
        i++;
      } else if (char === "/" && nextChar === "*") {
        isBlockComment = true;
        i++;
      } else {
        if (char === "\"") {
          isString = true;
        }
        result += char;
      }
    }
  }
  return result;
}
try {
  const jsonc = fs.readFileSync(process.argv[1], "utf8");
  const cleanJson = stripComments(jsonc);
  const config = JSON.parse(cleanJson);
  console.log(config.remoteUser || config.containerUser || "vscode");
} catch (e) {
  console.log("vscode");
}
' "$CONFIG")
            if [[ "$expected_user" == "root" ]]; then
                DOTFILES_TARGET_PATH="/root/dotfiles"
            else
                DOTFILES_TARGET_PATH="/home/${expected_user}/dotfiles"
            fi
        fi
        return 0
    fi

    # Si el contenedor existe (corriendo o detenido), extraer la config usada de sus labels
    if [[ "$CONTAINER_STATE" != "missing" ]] && [[ -n "$CONTAINER_ID" ]]; then
        local existing_config
        existing_config=$(docker inspect --format '{{index .Config.Labels "devcontainer.config_file"}}' "$CONTAINER_ID" 2>/dev/null || true)
        if [[ -n "$existing_config" ]]; then
            CONFIG="$existing_config"
            CONFIG=$(readlink -f "$CONFIG")
            CONFIG_FOR_CLI="$CONFIG"
            if [[ "$CONFIG" == "$RESOLVED_PWD/"* ]]; then
                CONFIG_FOR_CLI="${CONFIG#$RESOLVED_PWD/}"
            fi

            # Auto-completar ruta destino de dotfiles
            if [[ -z "$DOTFILES_TARGET_PATH" ]]; then
                local expected_user
                expected_user=$(node -e '
const fs = require("fs");
function stripComments(jsonc) {
  let isString = false;
  let isLineComment = false;
  let isBlockComment = false;
  let result = "";
  for (let i = 0; i < jsonc.length; i++) {
    const char = jsonc[i];
    const nextChar = jsonc[i + 1];
    if (isLineComment) {
      if (char === "\n" || char === "\r") {
        isLineComment = false;
        result += char;
      }
    } else if (isBlockComment) {
      if (char === "*" && nextChar === "/") {
        isBlockComment = false;
        i++;
      }
    } else if (isString) {
      if (char === "\"" && jsonc[i - 1] !== "\\") {
        isString = false;
      }
      result += char;
    } else {
      if (char === "/" && nextChar === "/") {
        isLineComment = true;
        i++;
      } else if (char === "/" && nextChar === "*") {
        isBlockComment = true;
        i++;
      } else {
        if (char === "\"") {
          isString = true;
        }
        result += char;
      }
    }
  }
  return result;
}
try {
  const jsonc = fs.readFileSync(process.argv[1], "utf8");
  const cleanJson = stripComments(jsonc);
  const config = JSON.parse(cleanJson);
  console.log(config.remoteUser || config.containerUser || "vscode");
} catch (e) {
  console.log("vscode");
}
' "$CONFIG")
                if [[ "$expected_user" == "root" ]]; then
                    DOTFILES_TARGET_PATH="/root/dotfiles"
                else
                    DOTFILES_TARGET_PATH="/home/${expected_user}/dotfiles"
                fi
            fi
            return 0
        fi
    fi

    if [[ -n "${DEVCONTAINER_CONFIG:-}" ]]; then
        CONFIG="$DEVCONTAINER_CONFIG"
        if [[ ! -f "$CONFIG" ]]; then
            log_error "El archivo configurado en DEVCONTAINER_CONFIG no existe: $CONFIG"
            exit 1
        fi
    else
        local configs=()
        if [[ -d ".devcontainer" ]]; then
            while IFS= read -r file; do
                configs+=("$file")
            done < <(find .devcontainer -type f -name "devcontainer.json" | sort)
        fi
        if [[ -f ".devcontainer.json" ]]; then
            configs+=(".devcontainer.json")
        fi

        if [[ ${#configs[@]} -eq 0 ]]; then
            log_error "No se encontró ningún archivo devcontainer.json válido."
            log_error "Asegúrate de estar en la raíz de un proyecto con carpeta .devcontainer/"
            exit 1
        elif [[ ${#configs[@]} -eq 1 ]]; then
            CONFIG="${configs[0]}"
        else
            if [[ -n "$ACTION" ]]; then
                CONFIG="${configs[0]}"
                log_info "Múltiples configuraciones detectadas. Usando '${CONFIG}' por defecto."
            else
                if command -v gum >/dev/null 2>&1; then
                    log_info "Selecciona el devcontainer.json a usar:"
                    CONFIG=$(gum choose "${configs[@]}")
                else
                    log_info "Múltiples archivos devcontainer.json detectados:"
                    select opt in "${configs[@]}"; do
                        if [[ -n "$opt" ]]; then
                            CONFIG="$opt"
                            break
                        else
                            echo "Selección inválida."
                        fi
                    done
                fi
            fi
        fi
    fi

    CONFIG=$(readlink -f "$CONFIG")
    CONFIG_FOR_CLI="$CONFIG"
    if [[ "$CONFIG" == "$RESOLVED_PWD/"* ]]; then
        CONFIG_FOR_CLI="${CONFIG#$RESOLVED_PWD/}"
    fi

    # Auto-completar ruta destino de dotfiles en base al usuario esperado si no está explícita
    if [[ -z "$DOTFILES_TARGET_PATH" ]]; then
        # Leemos el remoteUser para determinar si es root o vscode/otro
        local expected_user
        expected_user=$(node -e '
const fs = require("fs");
function stripComments(jsonc) {
  let isString = false;
  let isLineComment = false;
  let isBlockComment = false;
  let result = "";
  for (let i = 0; i < jsonc.length; i++) {
    const char = jsonc[i];
    const nextChar = jsonc[i + 1];
    if (isLineComment) {
      if (char === "\n" || char === "\r") {
        isLineComment = false;
        result += char;
      }
    } else if (isBlockComment) {
      if (char === "*" && nextChar === "/") {
        isBlockComment = false;
        i++;
      }
    } else if (isString) {
      if (char === "\"" && jsonc[i - 1] !== "\\") {
        isString = false;
      }
      result += char;
    } else {
      if (char === "/" && nextChar === "/") {
        isLineComment = true;
        i++;
      } else if (char === "/" && nextChar === "*") {
        isBlockComment = true;
        i++;
      } else {
        if (char === "\"") {
          isString = true;
        }
        result += char;
      }
    }
  }
  return result;
}
try {
  const jsonc = fs.readFileSync(process.argv[1], "utf8");
  const cleanJson = stripComments(jsonc);
  const config = JSON.parse(cleanJson);
  console.log(config.remoteUser || config.containerUser || "vscode");
} catch (e) {
  console.log("vscode");
}
' "$CONFIG")
        if [[ "$expected_user" == "root" ]]; then
            DOTFILES_TARGET_PATH="/root/dotfiles"
        else
            DOTFILES_TARGET_PATH="/home/${expected_user}/dotfiles"
        fi
    fi
}

# --- CONFIGURACIÓN DE AGENTE SSH ---
setup_ssh() {
    YOBYDEV_SSH_MODE="none"

    if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
        local user_uid=$(id -u)
        if [[ -S "/run/user/${user_uid}/keyring/ssh" ]]; then
            export SSH_AUTH_SOCK="/run/user/${user_uid}/keyring/ssh"
        elif [[ -S "/run/user/${user_uid}/gnupg/S.gpg-agent.ssh" ]]; then
            export SSH_AUTH_SOCK="/run/user/${user_uid}/gnupg/S.gpg-agent.ssh"
        else
            local temp_socket
            temp_socket=$(find /tmp/ssh-* -type s -user "$USER" -name "agent.*" 2>/dev/null | head -n 1 || true)
            if [[ -n "$temp_socket" ]]; then
                export SSH_AUTH_SOCK="$temp_socket"
            fi
        fi
    fi

    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        if [[ -S "$SSH_AUTH_SOCK" ]] && ssh-add -l >/dev/null 2>&1; then
            YOBYDEV_SSH_MODE="agent"
        elif [[ -S "$SSH_AUTH_SOCK" ]]; then
            if [[ -d "$HOME/.ssh" ]] && ls "$HOME/.ssh"/id_* >/dev/null 2>&1; then
                YOBYDEV_SSH_MODE="keys"
            fi
        fi
    fi

    if [[ "$YOBYDEV_SSH_MODE" == "none" ]] && [[ -d "$HOME/.ssh" ]] && ls "$HOME/.ssh"/id_* >/dev/null 2>&1; then
        YOBYDEV_SSH_MODE="keys"
    fi
}

# --- CONSTRUCCIÓN DINÁMICA DEL OVERRIDE (SSH Y CACHÉ) ---
generate_override() {
    log_info "Generando override de configuración libre de Git..."
    
    local workspace_hash
    workspace_hash=$(echo -n "$RESOLVED_PWD" | sha256sum | awk '{print $1}')
    
    local override_dir="$HOME/.cache/yobydev/workspaces/${workspace_hash}"
    mkdir -p "$override_dir"
    OVERRIDE_FILE="${override_dir}/devcontainer.override.json"

    # Asegurar existencia de las carpetas de caché en el host
    mkdir -p "$HOME/.cache/yobydev/caches/"{npm,pnpm,yarn,go,cargo,pip,composer}

    # Combinación robusta usando node
    node -e '
const fs = require("fs");
const path = require("path");

function stripComments(jsonc) {
  let isString = false;
  let isLineComment = false;
  let isBlockComment = false;
  let result = "";
  for (let i = 0; i < jsonc.length; i++) {
    const char = jsonc[i];
    const nextChar = jsonc[i + 1];
    if (isLineComment) {
      if (char === "\n" || char === "\r") {
        isLineComment = false;
        result += char;
      }
    } else if (isBlockComment) {
      if (char === "*" && nextChar === "/") {
        isBlockComment = false;
        i++;
      }
    } else if (isString) {
      if (char === "\"" && jsonc[i - 1] !== "\\") {
        isString = false;
      }
      result += char;
    } else {
      if (char === "/" && nextChar === "/") {
        isLineComment = true;
        i++;
      } else if (char === "/" && nextChar === "*") {
        isBlockComment = true;
        i++;
      } else {
        if (char === "\"") {
          isString = true;
        }
        result += char;
      }
    }
  }
  return result;
}

try {
  const configFile = process.argv[1];
  const overrideFile = process.argv[2];
  const cacheDir = process.argv[3];
  const sshMode = process.argv[4] || "none";
  const homeDir = process.argv[5] || "";
  const workspaceRoot = process.argv[6] || "";
  const sshAuthSock = process.env.SSH_AUTH_SOCK;
  const githubToken = process.env.GITHUB_TOKEN;

  const jsonc = fs.readFileSync(configFile, "utf8");
  const cleanJson = stripComments(jsonc);
  const config = JSON.parse(cleanJson);

  if (!config.mounts) {
    config.mounts = [];
  }
  if (!config.remoteEnv) {
    config.remoteEnv = {};
  }

  const remoteUser = config.remoteUser || config.containerUser || "vscode";
  const containerHome = remoteUser === "root" ? "/root" : `/home/${remoteUser}`;

  // Forwarding SSH
  if (sshMode === "agent" && sshAuthSock) {
    config.mounts.push("source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind");
    config.remoteEnv.SSH_AUTH_SOCK = "/ssh-agent";
  } else if (sshMode === "keys" && homeDir) {
    config.mounts.push(`source=${homeDir}/.ssh,target=${containerHome}/.ssh,type=bind,readonly`);
  }

  // Caché de herramientas
  if (cacheDir) {
    config.mounts.push(`source=${cacheDir},target=/tmp/yobydev-tools-cache,type=bind`);
    config.remoteEnv.DOTFILES_CACHE_DIR = "/tmp/yobydev-tools-cache";
  }

  // Caches específicas por lenguajes (Detección estática)
  const hasPackageJson = fs.existsSync(path.join(workspaceRoot, "package.json"));
  const hasGoMod = fs.existsSync(path.join(workspaceRoot, "go.mod"));
  const hasCargoToml = fs.existsSync(path.join(workspaceRoot, "Cargo.toml"));
  const hasRequirements = fs.existsSync(path.join(workspaceRoot, "requirements.txt")) || 
                          fs.existsSync(path.join(workspaceRoot, "pyproject.toml")) || 
                          fs.existsSync(path.join(workspaceRoot, "Pipfile"));
  const hasComposer = fs.existsSync(path.join(workspaceRoot, "composer.json"));

  if (hasPackageJson) {
    config.mounts.push(`source=${homeDir}/.cache/yobydev/caches/npm,target=${containerHome}/.npm,type=bind`);
    config.mounts.push(`source=${homeDir}/.cache/yobydev/caches/pnpm,target=${containerHome}/.local/share/pnpm/store,type=bind`);
    config.mounts.push(`source=${homeDir}/.cache/yobydev/caches/yarn,target=${containerHome}/.cache/yarn,type=bind`);
  }
  if (hasGoMod) {
    config.mounts.push(`source=${homeDir}/.cache/yobydev/caches/go,target=${containerHome}/go,type=bind`);
  }
  if (hasCargoToml) {
    config.mounts.push(`source=${homeDir}/.cache/yobydev/caches/cargo,target=${containerHome}/.cargo,type=bind`);
  }
  if (hasRequirements) {
    config.mounts.push(`source=${homeDir}/.cache/yobydev/caches/pip,target=${containerHome}/.cache/pip,type=bind`);
  }
  if (hasComposer) {
    config.mounts.push(`source=${homeDir}/.cache/yobydev/caches/composer,target=${containerHome}/.cache/composer,type=bind`);
  }

  if (githubToken) {
    config.remoteEnv.GITHUB_TOKEN = "${localEnv:GITHUB_TOKEN}";
  }

  fs.writeFileSync(overrideFile, JSON.stringify(config, null, 2), "utf8");
} catch (e) {
  console.error("Fallo al generar el archivo de override fusionado:", e.message);
  process.exit(1);
}
' "$CONFIG" "$OVERRIDE_FILE" "$YOBYDEV_CACHE_DIR" "$YOBYDEV_SSH_MODE" "$HOME" "$RESOLVED_PWD"
}

# --- CONTROL DE CONFIRMACIONES ---
confirm_action() {
    local msg="$1"
    if [[ "$FORCE" == "true" ]]; then
        return 0
    fi
    if command -v gum >/dev/null 2>&1; then
        gum confirm "$msg"
    else
        read -r -p "$msg [y/N]: " resp
        [[ "${resp,,}" == "y" || "${resp,,}" == "yes" ]]
    fi
}

# --- DETECCIÓN Y COPÍA DE LLAVES SSH ---
ensure_ssh_keys() {
    detect_container
    if [[ "$CONTAINER_STATE" == "running" ]]; then
        local has_agent=false
        if docker exec "$CONTAINER_ID" ssh-add -l >/dev/null 2>&1; then
            has_agent=true
        fi

        if ! $has_agent; then
            local container_user
            container_user=$(devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" whoami 2>/dev/null | tr -d '\r\n' || echo "vscode")
            container_user="${container_user:-vscode}"
            
            local container_home
            container_home=$(devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" sh -c 'echo "$HOME"' 2>/dev/null | tr -d '\r\n' || echo "/home/${container_user}")
            container_home="${container_home:-/home/$container_user}"
            if [[ "$container_user" == "root" ]]; then
                container_home="/root"
            fi
            
            if [[ -d "$HOME/.ssh" ]]; then
                log_info "Asegurando llaves SSH (~/.ssh) en $container_home/.ssh..."
                docker exec "$CONTAINER_ID" mkdir -p "$container_home/.ssh" 2>/dev/null || true
                docker cp "$HOME/.ssh/." "$CONTAINER_ID:$container_home/.ssh/"
                
                docker exec "$CONTAINER_ID" chown -R "$container_user" "$container_home/.ssh" 2>/dev/null || true
                docker exec "$CONTAINER_ID" chmod 700 "$container_home/.ssh" 2>/dev/null || true
                docker exec "$CONTAINER_ID" sh -c "chmod 600 $container_home/.ssh/* 2>/dev/null || true" || true
            fi
        fi
    fi
}

# --- CONTROLADORES DE DOTFILES EN EL CONTENEDOR ---
sync_dotfiles() {
    detect_container
    if [[ "$CONTAINER_STATE" != "running" ]]; then
        log_error "El contenedor no está corriendo. Imposible sincronizar dotfiles."
        return 1
    fi

    local dotfiles_host_dir
    dotfiles_host_dir=$(dirname "$(dirname "$(readlink -f "$0")")")

    log_info "Sincronizando dotfiles locales al contenedor en $DOTFILES_TARGET_PATH..."
    docker exec "$CONTAINER_ID" mkdir -p "$DOTFILES_TARGET_PATH" 2>/dev/null || true
    docker cp "${dotfiles_host_dir}/." "${CONTAINER_ID}:${DOTFILES_TARGET_PATH}/"
    
    local container_user
    container_user=$(devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" whoami 2>/dev/null | tr -d '\r\n' || echo "vscode")
    container_user="${container_user:-vscode}"
    
    docker exec "$CONTAINER_ID" chown -R "$container_user" "$DOTFILES_TARGET_PATH" 2>/dev/null || true
    docker exec "$CONTAINER_ID" sh -c "find $DOTFILES_TARGET_PATH -name '*.sh' -exec chmod +x {} \;" 2>/dev/null || true
}

run_dotfiles_installer() {
    detect_container
    if [[ "$CONTAINER_STATE" != "running" ]]; then
        log_error "El contenedor no está corriendo. Imposible ejecutar instalador."
        return 1
    fi

    local container_user
    container_user=$(devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" whoami 2>/dev/null | tr -d '\r\n' || echo "vscode")
    container_user="${container_user:-vscode}"

    local container_home
    container_home=$(devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" sh -c 'echo "$HOME"' 2>/dev/null | tr -d '\r\n' || echo "/home/${container_user}")
    container_home="${container_home:-/home/$container_user}"
    if [[ "$container_user" == "root" ]]; then
        container_home="/root"
    fi

    local install_shell
    if devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" bash -c "exit 0" >/dev/null 2>&1; then
        install_shell="bash"
    else
        install_shell="sh"
    fi

    log_info "Ejecutando script de instalación de dotfiles..."
    devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" "$install_shell" -c '
        set -e
        TARGET="$1"
        CMD="$2"
        MARKER_DIR="$3"
        MARKER="$3/installed"
        SUCCESS_MARKER="$3/success"
        
        mkdir -p "$MARKER_DIR"
        
        if [ ! -f "$MARKER" ] || [ ! -f "$SUCCESS_MARKER" ]; then
            rm -f "$SUCCESS_MARKER" 2>/dev/null || true
            
            if [ -n "$CMD" ]; then
                INSTALL_SCRIPT="$TARGET/$CMD"
                if [ -f "$INSTALL_SCRIPT" ]; then
                    echo -e "\e[34m[yobydev:dotfiles]\e[0m Ejecutando instalador: $INSTALL_SCRIPT..."
                    chmod +x "$INSTALL_SCRIPT"
                    if "$INSTALL_SCRIPT"; then
                        touch "$SUCCESS_MARKER"
                    else
                        echo -e "\e[33m[yobydev:dotfiles] WARNING: El script de instalación falló.\e[0m" >&2
                    fi
                elif [ -f "$TARGET/install.sh" ]; then
                    echo -e "\e[34m[yobydev:dotfiles]\e[0m Ejecutando instalador alternativo: $TARGET/install.sh..."
                    chmod +x "$TARGET/install.sh"
                    if "$TARGET/install.sh"; then
                        touch "$SUCCESS_MARKER"
                    else
                        echo -e "\e[33m[yobydev:dotfiles] WARNING: El script de instalación falló.\e[0m" >&2
                    fi
                else
                    echo -e "\e[33m[yobydev:dotfiles] WARNING: No se encontró script de instalación ($CMD).\e[0m" >&2
                fi
            fi
            touch "$MARKER"
            echo -e "\e[34m[yobydev:dotfiles]\e[0m Instalación completada."
        else
            echo -e "\e[34m[yobydev:dotfiles]\e[0m Dotfiles listos (marcador encontrado)."
        fi
    ' -- "$DOTFILES_TARGET_PATH" "$DOTFILES_INSTALL_COMMAND" "${container_home}/.yobydev"
}

force_dotfiles_reinstall() {
    detect_container
    if [[ "$CONTAINER_STATE" == "running" ]]; then
        local container_user
        container_user=$(devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" whoami 2>/dev/null | tr -d '\r\n' || echo "vscode")
        container_user="${container_user:-vscode}"
        
        local container_home
        container_home=$(devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" sh -c 'echo "$HOME"' 2>/dev/null | tr -d '\r\n' || echo "/home/${container_user}")
        container_home="${container_home:-/home/$container_user}"
        if [[ "$container_user" == "root" ]]; then
            container_home="/root"
        fi

        log_info "Restableciendo marcador de dotfiles para forzar la instalación..."
        docker exec "$CONTAINER_ID" rm -rf "${container_home}/.yobydev/installed" "${container_home}/.yobydev/success" 2>/dev/null || true
    fi
}

# --- ACCIONES INDIVIDUALES ---

action_open() {
    detect_container
    if [[ "$CONTAINER_STATE" == "running" ]]; then
        log_warn "El contenedor ya está corriendo. Conectando..."
        action_attach
        return
    elif [[ "$CONTAINER_STATE" == "exited" ]]; then
        action_start
        action_attach
        return
    fi

    detect_config
    setup_ssh
    generate_override

    log_info "Levantando el Dev Container..."
    if ! devcontainer up \
        --workspace-folder "$PWD" \
        --config "$CONFIG_FOR_CLI" \
        --override-config "$OVERRIDE_FILE" \
        --dotfiles-repository "$DOTFILES_REPOSITORY" \
        --dotfiles-target-path "$DOTFILES_TARGET_PATH" \
        --dotfiles-install-command "$DOTFILES_INSTALL_COMMAND"; then
        log_warn "devcontainer up finalizó con código de error. Intentando sincronización local..."
    fi

    sync_dotfiles
    run_dotfiles_installer
    action_attach
}

action_reopen() {
    detect_container
    if [[ "$CONTAINER_STATE" == "missing" ]]; then
        action_open
        return
    elif [[ "$CONTAINER_STATE" == "exited" ]]; then
        action_start
    fi

    force_dotfiles_reinstall
    sync_dotfiles
    run_dotfiles_installer
    action_attach
}

action_attach() {
    detect_container
    if [[ "$CONTAINER_STATE" == "missing" ]]; then
        log_error "El contenedor no existe. Ejecuta 'yobydev open' para crearlo."
        exit 1
    elif [[ "$CONTAINER_STATE" == "exited" ]]; then
        action_start
    fi

    local shell_cmd
    if devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" bash -c "exit 0" >/dev/null 2>&1; then
        shell_cmd="bash"
    else
        shell_cmd="sh"
    fi

    log_info "Entrando al contenedor..."
    exec devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" "$shell_cmd"
}

action_rebuild() {
    detect_container
    # Detectar la configuración antes de destruir el contenedor para recordar el archivo original
    detect_config

    if [[ "$CONTAINER_STATE" != "missing" ]]; then
        if ! confirm_action "¿Estás seguro de reconstruir el contenedor? Se perderá el estado interno."; then
            log_info "Cancelado."
            return
        fi
        log_info "Destruyendo contenedor previo..."
        docker rm -f "$CONTAINER_ID" >/dev/null 2>&1 || true
    fi

    setup_ssh
    generate_override

    log_info "Reconstruyendo contenedor..."
    local up_opts=()
    if [[ "$NO_CACHE" == "true" ]]; then
        up_opts+=("--build-no-cache")
    fi

    if ! devcontainer up \
        --workspace-folder "$PWD" \
        --config "$CONFIG_FOR_CLI" \
        --override-config "$OVERRIDE_FILE" \
        --dotfiles-repository "$DOTFILES_REPOSITORY" \
        --dotfiles-target-path "$DOTFILES_TARGET_PATH" \
        --dotfiles-install-command "$DOTFILES_INSTALL_COMMAND" \
        "${up_opts[@]}"; then
        log_warn "devcontainer up finalizó con error. Intentando recuperar..."
    fi

    sync_dotfiles
    run_dotfiles_installer
    action_attach
}

action_start() {
    detect_container
    if [[ "$CONTAINER_STATE" == "missing" ]]; then
        action_open
    elif [[ "$CONTAINER_STATE" == "running" ]]; then
        log_info "El contenedor ya está en ejecución."
    else
        log_info "Iniciando contenedor '$CONTAINER_NAME'..."
        docker start "$CONTAINER_ID" >/dev/null
        sleep 1
        ensure_ssh_keys
    fi
}

action_stop() {
    detect_container
    if [[ "$CONTAINER_STATE" == "running" ]]; then
        log_info "Deteniendo contenedor '$CONTAINER_NAME'..."
        docker stop "$CONTAINER_ID" >/dev/null
        log_info "Contenedor detenido con éxito."
    else
        log_info "El contenedor no está activo."
    fi
}

action_destroy() {
    detect_container
    if [[ "$CONTAINER_STATE" == "missing" ]]; then
        log_info "No se encontró ningún contenedor asociado a este workspace."
        return
    fi

    if ! confirm_action "¿Estás seguro de eliminar el contenedor '$CONTAINER_NAME'? Esta acción es irreversible."; then
        log_info "Operación cancelada."
        return
    fi

    log_info "Destruyendo contenedor '$CONTAINER_NAME' ($CONTAINER_ID)..."
    docker rm -f "$CONTAINER_ID" >/dev/null
    log_info "Contenedor destruido."
}

action_logs() {
    detect_container
    if [[ "$CONTAINER_STATE" == "missing" ]]; then
        log_error "No hay ningún contenedor corriendo o creado."
        exit 1
    fi

    if command -v gum >/dev/null 2>&1; then
        docker logs --tail 150 "$CONTAINER_ID" 2>&1 | gum pager
    else
        docker logs --tail 150 -f "$CONTAINER_ID"
    fi
}

# --- DISEÑO VISUAL CON GUM ---
styled_header() {
    local ws="$1"
    local config="$2"
    local state="$3"
    local cname="$4"

    if command -v gum >/dev/null 2>&1; then
        local header_text
        header_text="  yobydev\n"
        header_text+="  workspace: $ws\n"
        header_text+="  config:    $config\n"
        header_text+="  state:     $state\n"
        header_text+="  container: ${cname:-none}"

        gum style \
            --border rounded \
            --border-foreground "#7c3aed" \
            --foreground "#a78bfa" \
            --padding "0 2" \
            --margin "1 0" \
            "$header_text"
    else
        echo -e "\e[35;1m=== yobydev ===\e[0m"
        echo -e "workspace: \e[36m$ws\e[0m"
        echo -e "config:    \e[36m$config\e[0m"
        echo -e "state:     \e[36m$state\e[0m"
        echo -e "container: \e[36m${cname:-none}\e[0m"
        echo ""
    fi
}

styled_menu() {
    gum choose \
        --cursor "> " \
        --cursor.foreground "#7c3aed" \
        --item.foreground "#94a3b8" \
        --selected.foreground "#a78bfa" \
        --selected.bold \
        "$@"
}

# --- FLUJO DE EJECUCIÓN ---

detect_container
detect_config

# 1. Si hay un subcomando directo
if [[ -n "$ACTION" ]]; then
    case "$ACTION" in
        open) action_open ;;
        reopen) action_reopen ;;
        attach) action_attach ;;
        rebuild) action_rebuild ;;
        start) action_start ;;
        stop) action_stop ;;
        destroy) action_destroy ;;
        logs) action_logs ;;
    esac
    exit 0
fi

# 2. Si no hay subcomando, mostrar interfaz interactiva
WORKSPACE_NAME=$(basename "$RESOLVED_PWD")
styled_header "$WORKSPACE_NAME" "$CONFIG_FOR_CLI" "$CONTAINER_STATE" "$CONTAINER_NAME"

options=()
if [[ "$CONTAINER_STATE" == "running" ]]; then
    options=(
        "Reopen in Container      Sincronizar dotfiles y conectar"
        "Attach Shell             Conectar sin sincronizar"
        "Rebuild Container        Reconstruir y conectar"
        "Rebuild No Cache         Reconstruir desde cero"
        "Stop Container           Detener contenedor"
        "Destroy Container        Eliminar contenedor"
        "Container Logs           Ver logs"
    )
elif [[ "$CONTAINER_STATE" == "exited" ]]; then
    options=(
        "Start Container          Iniciar contenedor existente"
        "Reopen in Container      Iniciar, sincronizar y conectar"
        "Rebuild Container        Reconstruir y conectar"
        "Destroy Container        Eliminar contenedor"
        "Container Logs           Ver logs"
    )
else # missing
    options=(
        "Open in Container        Crear y conectar"
        "Rebuild No Cache         Crear desde cero sin cache"
    )
fi

if command -v gum >/dev/null 2>&1; then
    selection=$(styled_menu "${options[@]}")
    if [[ -z "$selection" ]]; then
        log_info "Cancelado."
        exit 0
    fi

    case "$selection" in
        "Reopen"*) action_reopen ;;
        "Attach"*) action_attach ;;
        "Rebuild Container"*) action_rebuild ;;
        "Rebuild No Cache"*) 
            NO_CACHE=true
            action_rebuild 
            ;;
        "Stop"*) action_stop ;;
        "Destroy"*) action_destroy ;;
        "Container Logs"*) action_logs ;;
        "Start"*) action_start ;;
        "Open"*) action_open ;;
    esac
else
    log_info "Selecciona una opción del menú:"
    select opt in "${options[@]}"; do
        if [[ -n "$opt" ]]; then
            case "$opt" in
                "Reopen"*) action_reopen ;;
                "Attach"*) action_attach ;;
                "Rebuild Container"*) action_rebuild ;;
                "Rebuild No Cache"*) 
                    NO_CACHE=true
                    action_rebuild 
                    ;;
                "Stop"*) action_stop ;;
                "Destroy"*) action_destroy ;;
                "Container Logs"*) action_logs ;;
                "Start"*) action_start ;;
                "Open"*) action_open ;;
            esac
            break
        else
            echo "Opción inválida."
        fi
    done
fi
