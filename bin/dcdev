#!/usr/bin/env bash
# ==============================================================================
# Script: dcdev
# Descripción: Wrapper local en el host que inyecta caché, token de GitHub,
#              agente SSH y levanta/conecta a un Dev Container usando devcontainer exec.
#              Soporta selección interactiva si hay múltiples devcontainer.json.
# ==============================================================================

set -euo pipefail

# --- CONFIGURACIÓN Y VALORES POR DEFECTO ---
DOTFILES_REPOSITORY="${DOTFILES_REPOSITORY:-git@github.com:yohanyflores/dotfiles.git}"
DOTFILES_INSTALL_COMMAND="${DOTFILES_INSTALL_COMMAND:-install-devcontainer.sh}"
DCDEV_CACHE_DIR="${DCDEV_CACHE_DIR:-$HOME/.cache/dcdev/tools}"

# Resuelve la ruta absoluta del target path evitando la evaluación literal de ~
if [[ "${DOTFILES_TARGET_PATH:-}" == "~/"* ]]; then
    DOTFILES_TARGET_PATH="${HOME}/${DOTFILES_TARGET_PATH#~/}"
else
    DOTFILES_TARGET_PATH="${DOTFILES_TARGET_PATH:-/home/vscode/dotfiles}"
fi

# --- COLORES Y LOGS ---
log_info() {
    echo -e "\e[34m[dcdev:INFO]\e[0m $*"
}

log_error() {
    echo -e "\e[31m[dcdev:ERROR]\e[0m $*" >&2
}

# --- 1. VERIFICACIONES EN EL HOST ---
for cmd in devcontainer docker jq; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        log_error "El ejecutable requerido '$cmd' no está disponible en el host."
        exit 1
    fi
done

# --- 2. CONFIGURACIÓN DE CACHÉ EN EL HOST ---
if [[ "$DCDEV_CACHE_DIR" == "~/"* ]]; then
    DCDEV_CACHE_DIR="${HOME}/${DCDEV_CACHE_DIR#~/}"
fi
mkdir -p "$DCDEV_CACHE_DIR"
DCDEV_CACHE_DIR=$(readlink -f "$DCDEV_CACHE_DIR")
log_info "Directorio de caché persistente en el host: $DCDEV_CACHE_DIR"

# --- 3. DETECCIÓN INTERACTIVA DEL ARCHIVO DE CONFIGURACIÓN ---
if [[ -n "${DEVCONTAINER_CONFIG:-}" ]]; then
    CONFIG="$DEVCONTAINER_CONFIG"
    if [[ ! -f "$CONFIG" ]]; then
        log_error "El archivo configurado en DEVCONTAINER_CONFIG no existe: $CONFIG"
        exit 1
    fi
else
    configs=()
    # Buscar todos los devcontainer.json en .devcontainer/ y la raíz
    if [[ -d ".devcontainer" ]]; then
        while IFS= read -r file; do
            configs+=("$file")
        done < <(find .devcontainer -type f -name "devcontainer.json" | sort)
    fi
    if [[ -f ".devcontainer.json" ]]; then
        configs+=(".devcontainer.json")
    fi

    if [[ ${#configs[@]} -eq 0 ]]; then
        log_error "No se encontró ningún archivo devcontainer.json válido."
        log_error "Asegúrate de estar en la raíz de un proyecto con carpeta .devcontainer/"
        exit 1
    elif [[ ${#configs[@]} -eq 1 ]]; then
        # Solo hay una configuración, se usa directamente
        CONFIG="${configs[0]}"
    else
        # Selección interactiva (múltiples configs)
        if command -v gum >/dev/null 2>&1; then
            log_info "Selecciona el devcontainer.json a ejecutar:"
            CONFIG=$(gum choose "${configs[@]}")
        else
            log_info "Múltiples archivos devcontainer.json detectados en el proyecto."
            echo "Por favor, selecciona una opción ingresando su número:"
            PS3="Número de opción: "
            # Habilitamos select interactivo
            select opt in "${configs[@]}"; do
                if [[ -n "$opt" ]]; then
                    CONFIG="$opt"
                    break
                else
                    echo "Selección inválida. Inténtalo de nuevo."
                fi
            done
        fi
    fi
fi

# Resolver rutas físicas absolutas para evitar discrepancias por enlaces simbólicos en el host (ej. /home/yohany/Develop -> /mnt/SSD-Linux/...)
RESOLVED_PWD=$(readlink -f "$PWD")
CONFIG=$(readlink -f "$CONFIG")

# Convertir a ruta relativa respecto al espacio de trabajo físico para evitar bugs de resolución en el CLI
CONFIG_FOR_CLI="$CONFIG"
if [[ "$CONFIG" == "$RESOLVED_PWD/"* ]]; then
    CONFIG_FOR_CLI="${CONFIG#$RESOLVED_PWD/}"
fi

log_info "Usando archivo de configuración seleccionado: $CONFIG (para el CLI: $CONFIG_FOR_CLI)"

# --- 4. CONSTRUCCIÓN DINÁMICA DEL OVERRIDE (SSH Y CACHÉ) ---
log_info "Generando override dinámico de configuración..."

# Determinar la carpeta de la configuración para colocar el override en el mismo directorio
CONFIG_DIR=$(dirname "$CONFIG")
OVERRIDE_FILE=$(mktemp "${CONFIG_DIR}/devcontainer-override-XXXXXX.json")

# Convertir el override a ruta relativa respecto al espacio de trabajo físico
OVERRIDE_FILE_FOR_CLI="$OVERRIDE_FILE"
if [[ "$OVERRIDE_FILE" == "$RESOLVED_PWD/"* ]]; then
    OVERRIDE_FILE_FOR_CLI="${OVERRIDE_FILE#$RESOLVED_PWD/}"
fi

# Limpieza segura al salir
trap 'rm -f "$OVERRIDE_FILE"' EXIT INT TERM

# Ejecutar Node para limpiar comentarios de la configuración base y combinarla con los overrides.
# Esto soluciona de raíz el bug del CLI de devcontainer al usar --override-config (que lee el archivo
# de override completo en lugar de fusionar parcialmente, requiriendo propiedades base de levantamiento).
node -e '
const fs = require("fs");

function stripComments(jsonc) {
  let isString = false;
  let isLineComment = false;
  let isBlockComment = false;
  let result = "";
  for (let i = 0; i < jsonc.length; i++) {
    const char = jsonc[i];
    const nextChar = jsonc[i + 1];
    if (isLineComment) {
      if (char === "\n" || char === "\r") {
        isLineComment = false;
        result += char;
      }
    } else if (isBlockComment) {
      if (char === "*" && nextChar === "/") {
        isBlockComment = false;
        i++;
      }
    } else if (isString) {
      if (char === "\"" && jsonc[i - 1] !== "\\") {
        isString = false;
      }
      result += char;
    } else {
      if (char === "/" && nextChar === "/") {
        isLineComment = true;
        i++;
      } else if (char === "/" && nextChar === "*") {
        isBlockComment = true;
        i++;
      } else {
        if (char === "\"") {
          isString = true;
        }
        result += char;
      }
    }
  }
  return result;
}

try {
  const configFile = process.argv[1];
  const overrideFile = process.argv[2];
  const cacheDir = process.argv[3];
  const sshAuthSock = process.env.SSH_AUTH_SOCK;
  const githubToken = process.env.GITHUB_TOKEN;

  const jsonc = fs.readFileSync(configFile, "utf8");
  const cleanJson = stripComments(jsonc);
  const config = JSON.parse(cleanJson);

  // Garantizar que las secciones de configuración existen
  if (!config.mounts) {
    config.mounts = [];
  }
  if (!config.remoteEnv) {
    config.remoteEnv = {};
  }

  // Soporte de SSH Agent
  if (sshAuthSock) {
    config.mounts.push("source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind");
    config.remoteEnv.SSH_AUTH_SOCK = "/ssh-agent";
  }

  // Soporte de caché de herramientas
  if (cacheDir) {
    config.mounts.push(`source=${cacheDir},target=/tmp/dcdev-tools-cache,type=bind`);
    config.remoteEnv.DOTFILES_CACHE_DIR = "/tmp/dcdev-tools-cache";
  }

  // Soporte de GITHUB_TOKEN
  if (githubToken) {
    config.remoteEnv.GITHUB_TOKEN = "${localEnv:GITHUB_TOKEN}";
  }

  fs.writeFileSync(overrideFile, JSON.stringify(config, null, 2), "utf8");
} catch (e) {
  console.error("Fallo al generar el archivo de override fusionado:", e.message);
  process.exit(1);
}
' "$CONFIG" "$OVERRIDE_FILE" "$DCDEV_CACHE_DIR"

log_info "Override JSON generado ($OVERRIDE_FILE_FOR_CLI):"
cat "$OVERRIDE_FILE"

# --- 5. LEVANTAR CONTENEDOR CON @DEVCONTAINERS/CLI ---
log_info "Levantando el Dev Container..."
log_info "Config: $CONFIG_FOR_CLI"

log_info "Ejecutando comando CLI de levantamiento:"
echo "devcontainer up \\"
echo "    --workspace-folder \"$PWD\" \\"
echo "    --config \"$CONFIG_FOR_CLI\" \\"
echo "    --override-config \"$OVERRIDE_FILE_FOR_CLI\" \\"
echo "    --dotfiles-repository \"$DOTFILES_REPOSITORY\" \\"
echo "    --dotfiles-target-path \"$DOTFILES_TARGET_PATH\" \\"
echo "    --dotfiles-install-command \"$DOTFILES_INSTALL_COMMAND\""

# Ejecutamos devcontainer up mostrando toda la salida a la terminal
if ! devcontainer up \
    --workspace-folder "$PWD" \
    --config "$CONFIG_FOR_CLI" \
    --override-config "$OVERRIDE_FILE_FOR_CLI" \
    --dotfiles-repository "$DOTFILES_REPOSITORY" \
    --dotfiles-target-path "$DOTFILES_TARGET_PATH" \
    --dotfiles-install-command "$DOTFILES_INSTALL_COMMAND"; then
    log_error "Fallo al ejecutar 'devcontainer up'."
    exit 1
fi

# --- 6. ENTRADA AL CONTENEDOR (DEVCONTAINER EXEC) ---
log_info "Entrando al contenedor..."

# Determinar si bash está disponible en el contenedor para devcontainer exec
if devcontainer exec --workspace-folder "$PWD" command -v bash >/dev/null 2>&1; then
    SHELL_CMD="bash"
else
    SHELL_CMD="sh"
fi

log_info "Ejecutando comando CLI de conexión:"
echo "devcontainer exec --workspace-folder \"$PWD\" \"$SHELL_CMD\""

exec devcontainer exec --workspace-folder "$PWD" "$SHELL_CMD"
