#!/usr/bin/env bash
# ==============================================================================
# Script: dcdev
# Descripción: Wrapper local en el host que inyecta caché, token de GitHub,
#              agente SSH y levanta/conecta a un Dev Container usando devcontainer exec.
#              Soporta selección interactiva si hay múltiples devcontainer.json.
# ==============================================================================

set -euo pipefail

# --- CONFIGURACIÓN Y VALORES POR DEFECTO ---
DOTFILES_REPOSITORY="${DOTFILES_REPOSITORY:-git@github.com:yohanyflores/dotfiles.git}"
DOTFILES_INSTALL_COMMAND="${DOTFILES_INSTALL_COMMAND:-install-devcontainer.sh}"
DCDEV_CACHE_DIR="${DCDEV_CACHE_DIR:-$HOME/.cache/dcdev/tools}"

# Resuelve la ruta absoluta del target path evitando la evaluación literal de ~
if [[ "${DOTFILES_TARGET_PATH:-}" == "~/"* ]]; then
    DOTFILES_TARGET_PATH="${HOME}/${DOTFILES_TARGET_PATH#~/}"
else
    DOTFILES_TARGET_PATH="${DOTFILES_TARGET_PATH:-/home/vscode/dotfiles}"
fi

# --- COLORES Y LOGS ---
log_info() {
    echo -e "\e[34m[dcdev:INFO]\e[0m $*"
}

log_warn() {
    echo -e "\e[33m[dcdev:WARN]\e[0m $*" >&2
}

log_error() {
    echo -e "\e[31m[dcdev:ERROR]\e[0m $*" >&2
}

# --- 1. VERIFICACIONES EN EL HOST ---
for cmd in devcontainer docker jq; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        log_error "El ejecutable requerido '$cmd' no está disponible en el host."
        exit 1
    fi
done

# --- 2. CONFIGURACIÓN DE CACHÉ Y SSH AGENT EN EL HOST ---
if [[ "$DCDEV_CACHE_DIR" == "~/"* ]]; then
    DCDEV_CACHE_DIR="${HOME}/${DCDEV_CACHE_DIR#~/}"
fi
mkdir -p "$DCDEV_CACHE_DIR"
DCDEV_CACHE_DIR=$(readlink -f "$DCDEV_CACHE_DIR")
log_info "Directorio de caché persistente en el host: $DCDEV_CACHE_DIR"

# Intentar auto-detectar SSH_AUTH_SOCK si no está definido en el entorno heredado
DCDEV_SSH_MODE="none"

if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
    log_info "SSH_AUTH_SOCK no heredado del entorno. Buscando agente SSH automáticamente..."
    USER_UID=$(id -u)
    if [[ -S "/run/user/${USER_UID}/keyring/ssh" ]]; then
        export SSH_AUTH_SOCK="/run/user/${USER_UID}/keyring/ssh"
        log_info "Agente SSH detectado (gnome-keyring): $SSH_AUTH_SOCK"
    elif [[ -S "/run/user/${USER_UID}/gnupg/S.gpg-agent.ssh" ]]; then
        export SSH_AUTH_SOCK="/run/user/${USER_UID}/gnupg/S.gpg-agent.ssh"
        log_info "Agente SSH detectado (gpg-agent): $SSH_AUTH_SOCK"
    else
        # Buscar sockets temporales del usuario actual
        TEMP_SOCKET=$(find /tmp/ssh-* -type s -user "$USER" -name "agent.*" 2>/dev/null | head -n 1 || true)
        if [[ -n "$TEMP_SOCKET" ]]; then
            export SSH_AUTH_SOCK="$TEMP_SOCKET"
            log_info "Agente SSH detectado (socket temporal): $SSH_AUTH_SOCK"
        else
            log_info "No se encontró ningún socket de agente SSH en rutas conocidas."
        fi
    fi
else
    log_info "SSH_AUTH_SOCK heredado del entorno: $SSH_AUTH_SOCK"
fi

if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
    # Verificar que el socket realmente existe y el agente responde
    if [[ -S "$SSH_AUTH_SOCK" ]] && ssh-add -l >/dev/null 2>&1; then
        DCDEV_SSH_MODE="agent"
        log_info "Agente SSH activo con llaves cargadas. Se usará forwarding del agente."
    elif [[ -S "$SSH_AUTH_SOCK" ]]; then
        log_warn "SSH_AUTH_SOCK apunta a '$SSH_AUTH_SOCK' pero no hay llaves cargadas (ejecuta 'ssh-add')."
        # El socket existe pero sin llaves — intentar fallback a ~/.ssh
        if [[ -d "$HOME/.ssh" ]] && ls "$HOME/.ssh"/id_* >/dev/null 2>&1; then
            DCDEV_SSH_MODE="keys"
            log_info "Fallback: se montará ~/.ssh (solo lectura) en el contenedor."
        fi
    else
        log_warn "SSH_AUTH_SOCK='$SSH_AUTH_SOCK' pero el socket no existe."
    fi
fi

# Si no hay agente, intentar montar ~/.ssh como último recurso
if [[ "$DCDEV_SSH_MODE" == "none" ]] && [[ -d "$HOME/.ssh" ]] && ls "$HOME/.ssh"/id_* >/dev/null 2>&1; then
    DCDEV_SSH_MODE="keys"
    log_info "Sin agente SSH, pero se encontraron llaves en ~/.ssh. Se montarán (solo lectura) en el contenedor."
fi

if [[ "$DCDEV_SSH_MODE" == "none" ]] && [[ "$DOTFILES_REPOSITORY" =~ ^(git@|ssh://) ]]; then
    log_warn "No se detectó agente SSH ni llaves en ~/.ssh."
    log_warn "Como tu repositorio de dotfiles usa SSH, la clonación FALLARÁ."
    log_warn "Sugerencia: Ejecuta 'eval (ssh-agent -c)' (en fish) o 'eval \$(ssh-agent)' (en bash/zsh) y añade tu llave con 'ssh-add'."
fi

# --- 3. DETECCIÓN DE CONTENEDOR EXISTENTE ---
RESOLVED_PWD=$(readlink -f "$PWD")

# Buscar contenedor corriendo para este workspace usando las labels del CLI
EXISTING_CONTAINER=$(docker ps -q \
    --filter "label=devcontainer.local_folder=${RESOLVED_PWD}" \
    2>/dev/null | head -1)

if [[ -n "$EXISTING_CONTAINER" ]]; then
    CONTAINER_NAME=$(docker inspect --format '{{.Name}}' "$EXISTING_CONTAINER" | sed 's|^/||')
    EXISTING_CONFIG=$(docker inspect --format '{{index .Config.Labels "devcontainer.config_file"}}' "$EXISTING_CONTAINER" 2>/dev/null || true)

    log_info "Contenedor existente detectado: $CONTAINER_NAME ($EXISTING_CONTAINER)"

    # Preguntar al usuario
    if command -v gum >/dev/null 2>&1; then
        CONNECT_DIRECT=$(gum confirm "¿Conectarse directamente al contenedor existente?" && echo "s" || echo "n")
    else
        read -r -p "[dcdev] ¿Conectarse directamente al contenedor existente? [S/n]: " CONNECT_DIRECT
        CONNECT_DIRECT="${CONNECT_DIRECT:-s}"
    fi

    if [[ "${CONNECT_DIRECT,,}" == "s" || "${CONNECT_DIRECT,,}" == "y" || -z "$CONNECT_DIRECT" ]]; then
        # Determinar config para exec
        CONFIG_FOR_CLI=""
        if [[ -n "$EXISTING_CONFIG" ]]; then
            CONFIG_FOR_CLI="$EXISTING_CONFIG"
            if [[ "$EXISTING_CONFIG" == "$RESOLVED_PWD/"* ]]; then
                CONFIG_FOR_CLI="${EXISTING_CONFIG#$RESOLVED_PWD/}"
            fi
        fi

        EXEC_OPTS=("--workspace-folder" "$PWD")
        if [[ -n "$CONFIG_FOR_CLI" ]]; then
            EXEC_OPTS+=("--config" "$CONFIG_FOR_CLI")
        fi

        # Determinar si bash está disponible en el contenedor para devcontainer exec
        if devcontainer exec "${EXEC_OPTS[@]}" bash -c "exit 0" >/dev/null 2>&1; then
            SHELL_CMD="bash"
        else
            SHELL_CMD="sh"
        fi

        # Saltar directamente a la conexión
        log_info "Conectando directamente al contenedor existente..."
        log_info "Ejecutando comando CLI de conexión:"
        echo "devcontainer exec ${EXEC_OPTS[*]} \"$SHELL_CMD\""
        exec devcontainer exec "${EXEC_OPTS[@]}" "$SHELL_CMD"
    fi
fi

# --- 4. DETECCIÓN INTERACTIVA DEL ARCHIVO DE CONFIGURACIÓN ---
if [[ -n "${DEVCONTAINER_CONFIG:-}" ]]; then
    CONFIG="$DEVCONTAINER_CONFIG"
    if [[ ! -f "$CONFIG" ]]; then
        log_error "El archivo configurado en DEVCONTAINER_CONFIG no existe: $CONFIG"
        exit 1
    fi
else
    configs=()
    # Buscar todos los devcontainer.json en .devcontainer/ y la raíz
    if [[ -d ".devcontainer" ]]; then
        while IFS= read -r file; do
            configs+=("$file")
        done < <(find .devcontainer -type f -name "devcontainer.json" | sort)
    fi
    if [[ -f ".devcontainer.json" ]]; then
        configs+=(".devcontainer.json")
    fi

    if [[ ${#configs[@]} -eq 0 ]]; then
        log_error "No se encontró ningún archivo devcontainer.json válido."
        log_error "Asegúrate de estar en la raíz de un proyecto con carpeta .devcontainer/"
        exit 1
    elif [[ ${#configs[@]} -eq 1 ]]; then
        # Solo hay una configuración, se usa directamente
        CONFIG="${configs[0]}"
    else
        # Selección interactiva (múltiples configs)
        if command -v gum >/dev/null 2>&1; then
            log_info "Selecciona el devcontainer.json a ejecutar:"
            CONFIG=$(gum choose "${configs[@]}")
        else
            log_info "Múltiples archivos devcontainer.json detectados en el proyecto."
            echo "Por favor, selecciona una opción ingresando su número:"
            PS3="Número de opción: "
            # Habilitamos select interactivo
            select opt in "${configs[@]}"; do
                if [[ -n "$opt" ]]; then
                    CONFIG="$opt"
                    break
                else
                    echo "Selección inválida. Inténtalo de nuevo."
                fi
            done
        fi
    fi
fi

# Resolver rutas físicas absolutas para evitar discrepancias por enlaces simbólicos en el host (ej. /home/yohany/Develop -> /mnt/SSD-Linux/...)
CONFIG=$(readlink -f "$CONFIG")

# Convertir a ruta relativa respecto al espacio de trabajo físico para evitar bugs de resolución en el CLI
CONFIG_FOR_CLI="$CONFIG"
if [[ "$CONFIG" == "$RESOLVED_PWD/"* ]]; then
    CONFIG_FOR_CLI="${CONFIG#$RESOLVED_PWD/}"
fi

log_info "Usando archivo de configuración seleccionado: $CONFIG (para el CLI: $CONFIG_FOR_CLI)"

# --- 5. CONSTRUCCIÓN DINÁMICA DEL OVERRIDE (SSH Y CACHÉ) ---
log_info "Generando override dinámico de configuración..."

# Determinar la carpeta de la configuración para colocar el override en el mismo directorio
CONFIG_DIR=$(dirname "$CONFIG")
OVERRIDE_FILE=$(mktemp "${CONFIG_DIR}/devcontainer-override-XXXXXX.json")

# Convertir el override a ruta relativa respecto al espacio de trabajo físico
OVERRIDE_FILE_FOR_CLI="$OVERRIDE_FILE"
if [[ "$OVERRIDE_FILE" == "$RESOLVED_PWD/"* ]]; then
    OVERRIDE_FILE_FOR_CLI="${OVERRIDE_FILE#$RESOLVED_PWD/}"
fi

# Limpieza segura al salir
trap 'rm -f "$OVERRIDE_FILE"' EXIT INT TERM

# Ejecutar Node para limpiar comentarios de la configuración base y combinarla con los overrides.
# Esto soluciona de raíz el bug del CLI de devcontainer al usar --override-config (que lee el archivo
# de override completo en lugar de fusionar parcialmente, requiriendo propiedades base de levantamiento).
node -e '
const fs = require("fs");

function stripComments(jsonc) {
  let isString = false;
  let isLineComment = false;
  let isBlockComment = false;
  let result = "";
  for (let i = 0; i < jsonc.length; i++) {
    const char = jsonc[i];
    const nextChar = jsonc[i + 1];
    if (isLineComment) {
      if (char === "\n" || char === "\r") {
        isLineComment = false;
        result += char;
      }
    } else if (isBlockComment) {
      if (char === "*" && nextChar === "/") {
        isBlockComment = false;
        i++;
      }
    } else if (isString) {
      if (char === "\"" && jsonc[i - 1] !== "\\") {
        isString = false;
      }
      result += char;
    } else {
      if (char === "/" && nextChar === "/") {
        isLineComment = true;
        i++;
      } else if (char === "/" && nextChar === "*") {
        isBlockComment = true;
        i++;
      } else {
        if (char === "\"") {
          isString = true;
        }
        result += char;
      }
    }
  }
  return result;
}

try {
  const configFile = process.argv[1];
  const overrideFile = process.argv[2];
  const cacheDir = process.argv[3];
  const sshMode = process.argv[4] || "none";
  const homeDir = process.argv[5] || "";
  const sshAuthSock = process.env.SSH_AUTH_SOCK;
  const githubToken = process.env.GITHUB_TOKEN;

  const jsonc = fs.readFileSync(configFile, "utf8");
  const cleanJson = stripComments(jsonc);
  const config = JSON.parse(cleanJson);

  // Garantizar que las secciones de configuración existen
  if (!config.mounts) {
    config.mounts = [];
  }
  if (!config.remoteEnv) {
    config.remoteEnv = {};
  }

  // Soporte de SSH según el modo detectado
  if (sshMode === "agent" && sshAuthSock) {
    // Modo preferido: forwarding del agente SSH via socket
    config.mounts.push("source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind");
    config.remoteEnv.SSH_AUTH_SOCK = "/ssh-agent";
  } else if (sshMode === "keys" && homeDir) {
    // Fallback: montar el directorio ~/.ssh completo (solo lectura)
    config.mounts.push(`source=${homeDir}/.ssh,target=/home/vscode/.ssh,type=bind,readonly`);
  }

  // Soporte de caché de herramientas
  if (cacheDir) {
    config.mounts.push(`source=${cacheDir},target=/tmp/dcdev-tools-cache,type=bind`);
    config.remoteEnv.DOTFILES_CACHE_DIR = "/tmp/dcdev-tools-cache";
  }

  // Soporte de GITHUB_TOKEN
  if (githubToken) {
    config.remoteEnv.GITHUB_TOKEN = "${localEnv:GITHUB_TOKEN}";
  }

  fs.writeFileSync(overrideFile, JSON.stringify(config, null, 2), "utf8");
} catch (e) {
  console.error("Fallo al generar el archivo de override fusionado:", e.message);
  process.exit(1);
}
' "$CONFIG" "$OVERRIDE_FILE" "$DCDEV_CACHE_DIR" "$DCDEV_SSH_MODE" "$HOME"

log_info "Override JSON generado ($OVERRIDE_FILE_FOR_CLI):"
cat "$OVERRIDE_FILE"

# --- 6. ELIMINAR MARCADOR DE DOTFILES Y ASEGURAR LLAVES SSH EN CONTENEDOR EXISTENTE ---
# Buscar contenedor corriendo para este workspace usando las labels del CLI
EXISTING_CONTAINER_FOR_MARKER=$(docker ps -q \
    --filter "label=devcontainer.local_folder=${RESOLVED_PWD}" \
    2>/dev/null | head -1)

if [[ -n "$EXISTING_CONTAINER_FOR_MARKER" ]]; then
    log_info "Eliminando marcador de dotfiles del contenedor existente para forzar la instalación..."
    docker exec "$EXISTING_CONTAINER_FOR_MARKER" sh -c '
        # Eliminar el marcador en el HOME actual y en rutas comunes
        rm -f "$HOME/.devcontainer/.dotfilesMarker" \
              "/home/vscode/.devcontainer/.dotfilesMarker" \
              "/home/node/.devcontainer/.dotfilesMarker" \
              "/root/.devcontainer/.dotfilesMarker" 2>/dev/null || true
    ' || true

    # Verificar si el contenedor ya tiene un agente SSH activo y respondiendo
    HAS_AGENT=false
    if docker exec "$EXISTING_CONTAINER_FOR_MARKER" ssh-add -l >/dev/null 2>&1; then
        HAS_AGENT=true
    fi

    if ! $HAS_AGENT; then
        # Detectar usuario remoto y home en el contenedor usando devcontainer exec (es el método más preciso)
        CONTAINER_USER=$(devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" whoami 2>/dev/null | tr -d '\r\n' || echo "vscode")
        CONTAINER_USER="${CONTAINER_USER:-vscode}"
        
        CONTAINER_HOME=$(devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" sh -c 'echo "$HOME"' 2>/dev/null | tr -d '\r\n' || echo "/home/vscode")
        CONTAINER_HOME="${CONTAINER_HOME:-/home/$CONTAINER_USER}"
        
        # Si el host tiene llaves en ~/.ssh, copiarlas
        if [[ -d "$HOME/.ssh" ]]; then
            log_info "El contenedor existente no tiene agente SSH activo. Asegurando llaves SSH (~/.ssh) en $CONTAINER_HOME/.ssh..."
            docker exec "$EXISTING_CONTAINER_FOR_MARKER" mkdir -p "$CONTAINER_HOME/.ssh" 2>/dev/null || true
            docker cp "$HOME/.ssh/." "$EXISTING_CONTAINER_FOR_MARKER:$CONTAINER_HOME/.ssh/"
            
            # Ajustar permisos y propietario
            docker exec "$EXISTING_CONTAINER_FOR_MARKER" chown -R "$CONTAINER_USER" "$CONTAINER_HOME/.ssh" 2>/dev/null || true
            docker exec "$EXISTING_CONTAINER_FOR_MARKER" chmod 700 "$CONTAINER_HOME/.ssh" 2>/dev/null || true
            docker exec "$EXISTING_CONTAINER_FOR_MARKER" sh -c "chmod 600 $CONTAINER_HOME/.ssh/* 2>/dev/null || true" || true
        fi
    fi
fi

# --- 7. LEVANTAR CONTENEDOR CON @DEVCONTAINERS/CLI ---
log_info "Levantando el Dev Container..."
log_info "Config: $CONFIG_FOR_CLI"

log_info "Ejecutando comando CLI de levantamiento:"
echo "devcontainer up \\"
echo "    --workspace-folder \"$PWD\" \\"
echo "    --config \"$CONFIG_FOR_CLI\" \\"
echo "    --override-config \"$OVERRIDE_FILE_FOR_CLI\" \\"
echo "    --dotfiles-repository \"$DOTFILES_REPOSITORY\" \\"
echo "    --dotfiles-target-path \"$DOTFILES_TARGET_PATH\" \\"
if [[ $# -gt 0 ]]; then
    echo "    --dotfiles-install-command \"$DOTFILES_INSTALL_COMMAND\" \\"
    echo "    $*"
else
    echo "    --dotfiles-install-command \"$DOTFILES_INSTALL_COMMAND\""
fi

# Ejecutamos devcontainer up mostrando toda la salida a la terminal y propagando argumentos adicionales
if ! devcontainer up \
    --workspace-folder "$PWD" \
    --config "$CONFIG_FOR_CLI" \
    --override-config "$OVERRIDE_FILE_FOR_CLI" \
    --dotfiles-repository "$DOTFILES_REPOSITORY" \
    --dotfiles-target-path "$DOTFILES_TARGET_PATH" \
    --dotfiles-install-command "$DOTFILES_INSTALL_COMMAND" \
    "$@"; then
    log_error "Fallo al ejecutar 'devcontainer up'."
    exit 1
fi

# --- 8. VERIFICACIÓN E INSTALACIÓN DE DOTFILES ---
log_info "Verificando instalación de dotfiles dentro del contenedor..."
if devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" bash -c "exit 0" >/dev/null 2>&1; then
    INSTALL_SHELL="bash"
else
    INSTALL_SHELL="sh"
fi

if ! devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" "$INSTALL_SHELL" -c '
    set -e
    REPO="$1"
    TARGET="$2"
    CMD="$3"
    MARKER="$HOME/.devcontainer/.dotfilesMarker"
    
    # Auto-recuperación: si existe el marcador pero no está el repositorio clonado con .git,
    # significa que la clonación anterior falló. Borramos el marcador para reintentar de verdad.
    if [ -f "$MARKER" ] && [ ! -d "$TARGET/.git" ]; then
        echo -e "\e[33m[dcdev:dotfiles] El marcador existe pero el repositorio no está clonado (.git no encontrado). Forzando re-instalación...\e[0m"
        rm -f "$MARKER"
    fi
    
    if [ ! -f "$MARKER" ]; then
        echo -e "\e[34m[dcdev:dotfiles]\e[0m No se encontró el marcador. Iniciando instalación de dotfiles..."
        
        # Clonar si no existe la carpeta o si no está inicializada con .git
        if [ ! -d "$TARGET/.git" ]; then
            # Si existía la carpeta sin .git (por ejemplo, vacía o fallida), la borramos primero
            if [ -d "$TARGET" ]; then
                echo -e "\e[33m[dcdev:dotfiles] Limpiando directorio de clonación fallido previo en $TARGET...\e[0m"
                rm -rf "$TARGET"
            fi
            
            echo -e "\e[34m[dcdev:dotfiles]\e[0m Clonando $REPO en $TARGET..."
            if ! git clone "$REPO" "$TARGET"; then
                echo -e "\e[31m[dcdev:dotfiles] ERROR: Falló la clonación del repositorio de dotfiles.\e[0m" >&2
                exit 1
            fi
        else
            echo -e "\e[34m[dcdev:dotfiles]\e[0m El directorio $TARGET ya está clonado (.git encontrado)."
        fi
        
        # Ejecutar comando de instalación
        if [ -n "$CMD" ]; then
            INSTALL_SCRIPT="$TARGET/$CMD"
            if [ -f "$INSTALL_SCRIPT" ]; then
                echo -e "\e[34m[dcdev:dotfiles]\e[0m Ejecutando instalador: $INSTALL_SCRIPT..."
                chmod +x "$INSTALL_SCRIPT"
                if ! "$INSTALL_SCRIPT"; then
                    echo -e "\e[33m[dcdev:dotfiles] WARNING: El script de instalación retornó un error.\e[0m" >&2
                fi
            elif [ -f "$TARGET/install.sh" ]; then
                echo -e "\e[34m[dcdev:dotfiles]\e[0m Ejecutando instalador alternativo: $TARGET/install.sh..."
                chmod +x "$TARGET/install.sh"
                if ! "$TARGET/install.sh"; then
                    echo -e "\e[33m[dcdev:dotfiles] WARNING: El script de instalación retornó un error.\e[0m" >&2
                fi
            else
                echo -e "\e[33m[dcdev:dotfiles] WARNING: No se encontró el script de instalación ($CMD).\e[0m" >&2
            fi
        fi
        
        # Crear marcador
        mkdir -p "$(dirname "$MARKER")"
        touch "$MARKER"
        echo -e "\e[34m[dcdev:dotfiles]\e[0m Instalación finalizada y marcador creado."
    else
        echo -e "\e[34m[dcdev:dotfiles]\e[0m Dotfiles ya instalados (marcador encontrado)."
    fi
' -- "$DOTFILES_REPOSITORY" "$DOTFILES_TARGET_PATH" "$DOTFILES_INSTALL_COMMAND"; then
    log_warn "No se pudo completar la instalación de dotfiles automáticamente."
fi

# --- 9. ENTRADA AL CONTENEDOR (DEVCONTAINER EXEC) ---
log_info "Entrando al contenedor..."

# Determinar si bash está disponible en el contenedor para devcontainer exec
if devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" bash -c "exit 0" >/dev/null 2>&1; then
    SHELL_CMD="bash"
else
    SHELL_CMD="sh"
fi

log_info "Ejecutando comando CLI de conexión:"
echo "devcontainer exec --workspace-folder \"$PWD\" --config \"$CONFIG_FOR_CLI\" \"$SHELL_CMD\""

exec devcontainer exec --workspace-folder "$PWD" --config "$CONFIG_FOR_CLI" "$SHELL_CMD"
