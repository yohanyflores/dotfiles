# Configuración de Git personal
# ~/.gitconfig

[user]
    name = Tu Nombre
    email = tu_correo@ejemplo.com

[core]
    editor = nvim
    excludesfile = ~/.gitignore_global
    pager = delta

[init]
    defaultBranch = main

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Coldark-Dark

[merge]
    conflictstyle = zdiff3

[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    lg = log --oneline --graph --decorate
