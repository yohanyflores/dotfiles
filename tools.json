{
  "tools": [
    {
      "name": "lazygit",
      "repo": "jesseduffield/lazygit",
      "version": "0.62.2",
      "pattern": "lazygit_${VERSION_NO_V}_Linux_${ARCH}.tar.gz",
      "profile": "core"
    },
    {
      "name": "just",
      "repo": "casey/just",
      "version": "1.53.0",
      "pattern": "just-${TAG}-${ARCH}-unknown-linux-musl.tar.gz",
      "profile": "core"
    },
    {
      "name": "zellij",
      "repo": "zellij-org/zellij",
      "version": "0.44.3",
      "pattern": "zellij-${ARCH}-unknown-linux-musl.tar.gz",
      "profile": "core"
    },
    {
      "name": "yq",
      "repo": "mikefarah/yq",
      "version": "4.53.3",
      "pattern": "yq_linux_${ARCH}",
      "profile": "core"
    },
    {
      "name": "bat",
      "repo": "sharkdp/bat",
      "version": "0.26.1",
      "pattern": "bat-v${VERSION_NO_V}-${ARCH}-unknown-linux-musl.tar.gz",
      "binary_inside": "bat",
      "profile": "nice"
    },
    {
      "name": "eza",
      "repo": "eza-community/eza",
      "version": "0.23.4",
      "pattern": "eza_${ARCH}-unknown-linux-musl.tar.gz",
      "binary_inside": "eza",
      "profile": "nice"
    },
    {
      "name": "delta",
      "repo": "dandavison/delta",
      "version": "0.19.2",
      "pattern": "delta-${TAG}-${ARCH}-unknown-linux-musl.tar.gz",
      "binary_inside": "delta",
      "profile": "nice"
    },
    {
      "name": "shfmt",
      "repo": "mvdan/sh",
      "version": "3.13.1",
      "pattern": "shfmt_v${VERSION_NO_V}_linux_${ARCH}",
      "profile": "nice"
    },
    {
      "name": "xh",
      "repo": "ducaale/xh",
      "version": "0.25.3",
      "pattern": "xh-v${VERSION_NO_V}-${ARCH}-unknown-linux-musl.tar.gz",
      "binary_inside": "xh",
      "profile": "nice"
    },
    {
      "name": "yazi",
      "repo": "sxyazi/yazi",
      "version": "26.5.6",
      "pattern": "yazi-${ARCH}-unknown-linux-musl.zip",
      "binary_inside": "yazi",
      "profile": "nice"
    },
    {
      "name": "micro",
      "repo": "zyedidia/micro",
      "version": "2.0.15",
      "pattern": "micro-${VERSION_NO_V}-${ARCH}.tar.gz",
      "binary_inside": "micro",
      "profile": "nice"
    },
    {
      "name": "gomplate",
      "repo": "hairyhenderson/gomplate",
      "version": "5.1.0",
      "pattern": "gomplate_linux-${ARCH}",
      "profile": "nice"
    },
    {
      "name": "gum",
      "repo": "charmbracelet/gum",
      "version": "0.17.0",
      "pattern": "gum_${VERSION_NO_V}_Linux_${ARCH}.tar.gz",
      "profile": "nice"
    }
  ]
}
